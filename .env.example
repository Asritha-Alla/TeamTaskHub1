# MongoDB Atlas connection string
# Create a free cluster at https://www.mongodb.com/atlas
# Make sure to allow 0.0.0.0/0 in Atlas Network Access for Railway/Replit
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskmaster?retryWrites=true&w=majority

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-string

# Session secret (legacy, any string works)
SESSION_SECRET=replace-with-any-string

# Server port — Railway sets this automatically; only needed for local dev
# PORT=8080
